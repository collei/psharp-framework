{
    "name": "collei/psharp-framework",
    "description": "Another PHP microframework for webapps",
    "license": "MIT",
    "keywords": [
        "framework",
        "psharp"
    ],
    "authors": [
        {
            "name": "Al Ju",
            "email": "alarido.su@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "nesbot/carbon": "^2.0 || ^3.0",
        "psr/http-factory": "^1.1",
        "psr/container": "^2.0",
        "psr/log": "^2.0 || ^3.0",
        "psr/simple-cache": "^2.0 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "PSharp\\": "src/PSharp",
            "App\\": "App"
        },
        "files": [
            "src/PSharp/helpers.php",
            "src/PSharp/facades.php"
        ]
    }
}