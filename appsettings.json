{
    "info": {
        "name": "My Test App",
        "description": "App constructed through PSharp evolution.",
        "version": 1
    },
    "logging": {
        "defaultChannel": "single",
        "defaultProfile": "info",
        "channels": {
            "stack": {
                "type": "stack",
                "channels": ["daily","single"]
            },
            "single": {
                "type": "single",
                "folder": "storage/logs",
                "dateFormat": "Y-m-d H:i:s.u",
                "fileNameFormat": "log.txt"
            },
            "daily": {
                "type": "daily",
                "folder": "storage/logs",
                "dateFormat": "Y-m-d H:i:s.u",
                "fileName": "log-{date:Y-m-d}.txt"
            },
            "email": {
                "type": "email",
                "subject": "storage/logs",
                "to": "webmaster@domain",
                "cc": []
            }
        }
    }
}